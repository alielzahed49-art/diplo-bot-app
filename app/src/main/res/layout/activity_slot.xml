<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#07071A"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚔"
        android:textSize="40sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#C8A84B"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:lineSpacingExtra="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="اختار الحساب"
        android:textColor="#888899"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Slot 1 -->
    <Button
        android:id="@+id/btn_slot1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🎮  استخراج توكن — حساب 1"
        android:textColor="#07071A"
        android:textStyle="bold"
        android:textSize="15sp"
        android:backgroundTint="#C8A84B"
        android:stateListAnimator="@null"
        android:layout_marginBottom="14dp"/>

    <!-- Slot 2 -->
    <Button
        android:id="@+id/btn_slot2"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🎮  استخراج توكن — حساب 2"
        android:textColor="#C8A84B"
        android:textStyle="bold"
        android:textSize="15sp"
        android:backgroundTint="#1A1A35"
        android:stateListAnimator="@null"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تسجيل خروج"
        android:textColor="#555566"
        android:textSize="12sp"
        android:backgroundTint="@android:color/transparent"
        android:stateListAnimator="@null"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MADE BY @K3lio"
        android:textColor="#333355"
        android:textSize="11sp"
        android:layout_marginTop="24dp"/>

</LinearLayout>
