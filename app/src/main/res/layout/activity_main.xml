<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:paddingTop="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔"
            android:textSize="48sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIPLOMACIA BOT"
            android:textColor="#C8A84B"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سجل دخولك لاستخراج التوكن"
            android:textColor="#6666AA"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="36dp"/>

        <!-- Bot URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="رابط البوت"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:hint="https://diplomacia-saas.onrender.com"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <!-- Username -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اسم المستخدم"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:hint="username"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="كلمة السر"
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E94560"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <ProgressBar
            android:id="@+id/pb_loading"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:progressTint="#C8A84B"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="دخول ←"
            android:textColor="#07071A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="#C8A84B"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MADE BY @K3lio"
            android:textColor="#333355"
            android:textSize="11sp"
            android:layout_marginTop="32dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
